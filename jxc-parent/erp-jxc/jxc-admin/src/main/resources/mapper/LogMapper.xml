<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spy.jxc.admin.mapper.LogMapper">

    <resultMap id="logMap" type="com.spy.jxc.admin.entity.Log">
        <id property="logId" column="log_id"/>
        <result property="logType" column="log_type"/>
        <result property="content" column="content"/>
        <result property="logDate" column="log_date"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
    </resultMap>

    <select id="listWithUser" resultMap="logMap">
        SELECT l.*, u.user_name
        FROM t_log l
        LEFT JOIN t_user u ON l.user_id = u.user_id
        <where>
            <if test="log.logType != null and log.logType != ''">
                AND l.log_type = #{log.logType}
            </if>
            <if test="log.startDate != null and log.startDate != ''">
                AND l.log_date &gt;= #{log.startDate}
            </if>
            <if test="log.endDate != null and log.endDate != ''">
                AND l.log_date &lt;= #{log.endDate}
            </if>
        </where>
        ORDER BY l.log_date DESC
    </select>
</mapper>
